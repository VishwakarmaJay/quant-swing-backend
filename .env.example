# ---- Runtime ----
NODE_ENV=development
PORT=3000

# ---- Database (PostgreSQL) ----
DATABASE_URL=""

# ---- Redis ----
REDIS_HOST=""
REDIS_PORT=6379

# ---- RabbitMQ (optional; wired in a later module) ----
# RABBITMQ_URL="amqp://guest:guest@localhost:5672"

# ---- Orders/Positions pollers (optional) ----
# ORDER_STATUS_POLL_MS=5000
# ORDER_CHASE_POLL_MS=5000
# POSITION_MTM_POLL_MS=180000
# POSITION_CLEANUP_POLL_MS=1800000

# ---- Auth ----
JWT_SECRET="change-me-to-a-long-random-string"

# ---- Angel One SmartAPI (from smartapi.angelone.in; LTP stream is disabled when unset) ----
# ANGELONE_API_KEY=""
# ANGELONE_CLIENT_CODE=""
# ANGELONE_MPIN=""
# ANGELONE_TOTP_SECRET=""

# ---- Seed (used by `bun run seed`) ----
# SEED_USER_EMAIL="admin@quantswing.local"
# SEED_USER_PASSWORD="ChangeMe123!"

# ---- Logging (optional: error | warn | info | debug) ----
# LOG_LEVEL=debug
