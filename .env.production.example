# QuantSwing production .env template (VM copy lives at ~/quantswing/.env).
# Copy to `.env` next to docker-compose.yml on the VM and fill in secrets.
# NEVER commit a filled-in copy.

# ---- images (optional) ----
# Leave unset to build locally on the box (`docker compose build`); set only
# when pulling prebuilt images from a registry.
#IMAGE_BACKEND=
#IMAGE_SIDECAR=

# ---- infrastructure (compose wires hosts; only the password is yours) ----
POSTGRES_PASSWORD=change-me
# DATABASE_URL / REDIS_HOST / REDIS_PORT / RABBITMQ_URL / SENTIMENT_SIDECAR_URL
# are set by docker-compose.yml — do not set them here.

NODE_ENV=production
PORT=3000

# ---- auth ----
JWT_SECRET=change-me

# ---- Angel One SmartAPI (optional; LTP stream disabled when unset) ----
#ANGELONE_API_KEY=
#ANGELONE_CLIENT_CODE=
#ANGELONE_MPIN=
#ANGELONE_TOTP_SECRET=

# ---- Telegram delivery (optional; alerts logged, not sent, when unset) ----
#TELEGRAM_BOT_TOKEN=
#TELEGRAM_CHAT_ID=

# ---- version stamp (set to the deployed git sha) ----
#ENGINE_VERSION=

# ---- tunables (defaults are sane; see src/config/env.ts) ----
#NEWS_INGEST_INTERVAL_MS=900000
#GDELT_BATCH_DAYS=30
#GDELT_LATENCY_MINUTES=30
#GDELT_RATE_LIMIT_MS=500
