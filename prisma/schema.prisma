// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// The single operator of the platform. Exactly one active user is expected
/// (single-user system, no signup/multi-user). BRL-001.
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders       Order[]
  brokerTokens BrokerToken[]
  positions    Position[]

  @@map("user")
}

/// Key-value application configuration (risk limits, trading windows,
/// instrument parameters, active strategies, paper/live mode). BRL-036.
model AppConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("app_config")
}

/// Tradable/watchable contracts from the Angel One scrip master, filtered to
/// the platform universe (index options on Nifty 50, Bank Nifty, Sensex plus
/// their underlying index rows). BRL-004/005.
model Instrument {
  /// `${exchSeg}:${symbol}` e.g. NFO:NIFTY29JAN2621000CE
  id             String    @id
  /// Angel One instrument token (used for the WS feed and orders)
  token          String
  /// Angel One trading symbol e.g. NIFTY29JAN2621000CE
  symbol         String
  /// Underlying name e.g. NIFTY, BANKNIFTY, SENSEX
  name           String
  expiry         DateTime? @db.Date
  strike         Float     @default(0)
  lotSize        Int       @default(1)
  tickSize       Float     @default(0)
  /// OPTIDX (index option), AMXIDX (underlying index), or EQ (NSE cash equity)
  instrumentType String
  /// NFO | BFO | NSE | BSE
  exchSeg        String
  /// Sector label for equities (RS peer group + portfolio 1-per-sector cap);
  /// null for index/option instruments.
  sector         String?
  /// Max quantity allowed per order on an index
  freezeQty      Int       @default(0)
  /// Last traded price, refreshed by the LTP stream (throttled fallback for the Redis cache)
  lastPrice      Float     @default(0)
  /// Cumulative day volume, refreshed by the LTP stream (Float: day volumes
  /// exceed the 2.1B integer cap, and BigInt does not JSON-serialize)
  volume         Float     @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  orders         Order[]
  tradeSetupLegs TradeSetupLeg[]
  positionLegs   PositionLeg[]
  candles        Ohlcv[]
  signals        Signal[]

  @@unique([exchSeg, token])
  @@index([symbol])
  @@index([name])
  @@index([expiry])
  @@index([instrumentType])
  @@index([sector])
  @@map("instrument")
}

/// Daily historical OHLCV candles, the research foundation for the factor
/// layer. Backfilled and kept current from the Angel One historical candle
/// API (getCandleData), independent of the live LTP stream. Append-only:
/// a re-fetch of an existing (instrument, date) overwrites in place via
/// upsert; rows are never deleted. Prices/volume are Float (matching
/// Instrument.lastPrice/volume — index day volumes exceed the int cap).
model Ohlcv {
  instrumentId String
  instrument   Instrument @relation(fields: [instrumentId], references: [id])
  /// Trading day of the candle (date only; daily interval).
  tradeDate    DateTime   @db.Date
  open   Float
  high   Float
  low    Float
  close  Float
  volume Float      @default(0)
  createdAt DateTime @default(now())

  /// PERF: PK covers the dominant query (instrument + date range).
  @@id([instrumentId, tradeDate])
  @@index([instrumentId, tradeDate])
  @@map("ohlcv")
}

/// Brokers the platform can route orders to. PAPER is the built-in
/// test/simulation broker (no external API; randomized outcomes).
enum Broker {
  PAPER
}

enum OrderStatus {
  /// Row created, placement queued, not yet accepted by the broker
  PENDING
  /// Accepted by the broker, unfilled
  OPEN
  /// Partially filled (kept for pipeline completeness; Chaos never emits it)
  PARTIAL
  COMPLETED
  CANCELLED
  REJECTED
}

enum OrderType {
  MARKET
  LIMIT
}

enum TransactionType {
  BUY
  SELL
}

enum ProductType {
  /// MIS — squared off same day
  INTRADAY
  /// NRML — carryforward
  NORMAL
}

enum TradeSetupStatus {
  ACTIVE
  ARCHIVED
}

enum PositionStatus {
  OPEN
  /// User asked to exit — legs reconcile toward zero until flat
  MARKED_FOR_EXIT
  CLOSED
}

/// Persisted display status (hedged ReadableStatusEnum). Recomputed by
/// syncPosition after every order state change.
enum ReadableStatus {
  SYNCED
  NOT_IN_SYNC
  IN_PROGRESS
  EXITED
}

/// User-defined multi-leg trade template (replaces hedged's B2CRecommendation
/// as the reconcile target). No versioning: the setup is the current truth.
model TradeSetup {
  id        String           @id @default(uuid())
  name      String
  status    TradeSetupStatus @default(ACTIVE)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  legs      TradeSetupLeg[]
  positions Position[]

  @@map("trade_setup")
}

model TradeSetupLeg {
  id           String          @id @default(uuid())
  tradeSetupId String
  tradeSetup   TradeSetup      @relation(fields: [tradeSetupId], references: [id])
  instrumentId String
  instrument   Instrument      @relation(fields: [instrumentId], references: [id])
  action       TransactionType
  /// Absolute target quantity at multiplier 1 (lots x lotSize), always positive
  quantity     Int
  entryPrice   Float?
  exitPrice    Float?
  createdAt    DateTime        @default(now())

  positionLegs PositionLeg[]

  @@index([tradeSetupId])
  @@map("trade_setup_leg")
}

/// A live instance of a TradeSetup. Held quantities are never stored — they
/// are derived from COMPLETED orders (hedged invariant).
model Position {
  id                String          @id @default(uuid())
  userId            String
  user              User            @relation(fields: [userId], references: [id])
  tradeSetupId      String
  tradeSetup        TradeSetup      @relation(fields: [tradeSetupId], references: [id])
  broker            Broker          @default(PAPER)
  status            PositionStatus  @default(OPEN)
  /// Scales every setup leg's target quantity
  userMultiplier    Int             @default(1)
  readableStatus    ReadableStatus?
  /// Realized P&L (MTM poller output)
  pnl               Float           @default(0)
  /// Unrealized MTM on remaining quantity (MTM poller output)
  calcUnrealisedPnl Float           @default(0)
  totalCharges      Float           @default(0)
  exitedAt          DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  legs   PositionLeg[]
  orders Order[]

  @@index([userId, status])
  @@index([tradeSetupId])
  @@map("position")
}

model PositionLeg {
  id              String          @id @default(uuid())
  positionId      String
  position        Position        @relation(fields: [positionId], references: [id])
  tradeSetupLegId String
  tradeSetupLeg   TradeSetupLeg   @relation(fields: [tradeSetupLegId], references: [id])
  instrumentId    String
  instrument      Instrument      @relation(fields: [instrumentId], references: [id])
  /// Snapshot of the setup leg's action at position creation
  action          TransactionType
  userId          String
  createdAt       DateTime        @default(now())

  orders Order[]

  @@index([positionId])
  @@map("position_leg")
}

/// A single order routed to a broker. BRL-010.
model Order {
  id           String     @id @default(uuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  instrumentId String
  instrument   Instrument @relation(fields: [instrumentId], references: [id])

  broker          Broker          @default(PAPER)
  status          OrderStatus     @default(PENDING)
  transactionType TransactionType
  orderType       OrderType
  productType     ProductType     @default(INTRADAY)
  quantity        Int
  /// Limit price. MARKET orders are resolved to a limit at placement time.
  price           Float           @default(0)

  /// Broker-side order id (e.g. PAPER-<id>); null until the broker accepts
  brokerOrderId         String?
  filledQuantity        Int       @default(0)
  averageExecutionPrice Float?
  rejectReason          String?
  placedAt              DateTime?
  executedAt            DateTime?
  cancelledAt           DateTime?

  /// OMS linkage — null for quick-ticket (positionless) orders
  positionId    String?
  position      Position?    @relation(fields: [positionId], references: [id])
  positionLegId String?
  positionLeg   PositionLeg? @relation(fields: [positionLegId], references: [id])

  /// Indian F&O charges, stamped when the order turns COMPLETED
  stt             Float?
  stampDuty       Float?
  exchangeCharges Float?
  sebiCharges     Float?
  brokerage       Float?
  gst             Float?
  totalCharges    Float?

  /// Price-chase state (restart-safe; chase poller re-quotes OPEN limit orders)
  chase         Boolean   @default(false)
  chaseAttempts Int       @default(0)
  chaseFailures Int       @default(0)
  lastChaseAt   DateTime?
  remarks       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  brokerLogs BrokerLog[]

  @@index([userId, status])
  @@index([status])
  @@index([brokerOrderId])
  @@index([createdAt])
  @@index([positionId])
  @@map("order")
}

/// Broker session token. Paper tokens are dummy plaintext strings; `meta`
/// carries { clientId, name, paperConfig }. TODO: encrypt `token` when the
/// first real broker is added.
model BrokerToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  broker    Broker
  token     String
  expiry    DateTime
  meta      Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, broker, expiry])
  @@map("broker_token")
}

/// Audit trail of every broker API call (real or simulated) so order flows can
/// be reconstructed later, mirroring what a live broker integration persists.
model BrokerLog {
  id            String   @id @default(uuid())
  broker        Broker
  method        String
  url           String
  request       Json?
  response      Json?
  isError       Boolean  @default(false)
  statusCode    Int      @default(200)
  /// Simulated/observed call duration in ms
  duration      Int      @default(0)
  orderId       String?
  order         Order?   @relation(fields: [orderId], references: [id])
  brokerOrderId String?
  userId        String?
  createdAt     DateTime @default(now())

  @@index([orderId])
  @@index([createdAt])
  @@map("broker_log")
}

/// Structured system/audit log persisted so any decision or action can be
/// reconstructed later. BRL-034.
model SystemLog {
  id        String   @id @default(uuid())
  level     String
  event     String
  message   String
  context   Json?
  requestId String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([level])
  @@index([event])
  @@map("system_log")
}

/// One nightly decision run — the summary + version stamps that make every
/// signal reproducible (docs ARCHITECTURE/NON_FUNCTIONAL). Append-only.
model SignalRun {
  id                   String   @id @default(uuid())
  createdAt            DateTime @default(now())
  asOf                 DateTime @db.Date
  marketRegime         String
  regimeDetail         String
  approvedCount        Int
  rejectedCount        Int
  engineVersion        String
  weightsVersion       String
  factorConfigChecksum String

  @@index([createdAt])
  @@map("signal_run")
}

/// An approved trade signal with its full snapshot + version stamps. Long-only
/// v1 (action BUY). Append-only; never mutated (docs DATABASE rules).
model Signal {
  id           String     @id @default(uuid())
  runId        String
  createdAt    DateTime   @default(now())
  asOf         DateTime   @db.Date
  instrumentId String
  instrument   Instrument @relation(fields: [instrumentId], references: [id])
  symbol       String
  sector       String?

  action         String  @default("BUY")
  entry          Float
  entryLow       Float
  entryHigh      Float
  stopLoss       Float
  target1        Float
  target2        Float
  riskPerShare   Float
  rrToResistance Float?
  atrPct         Float

  qty              Int
  positionValue    Float
  allocatedCapital Float
  riskAmount       Float

  compositeScore Float
  agreementScore Float
  marketRegime   String

  /// Full reproducibility snapshot (the approved signal + factor scores).
  snapshotJson            Json
  snapshotSchemaVersion   String
  weightsVersion          String
  /// git sha of the engine that produced this signal.
  engineVersion           String
  instrumentMasterVersion String
  constituentSnapshotDate DateTime @db.Date
  factorConfigChecksum    String

  @@index([runId])
  @@index([createdAt])
  @@index([instrumentId])
  @@map("signal")
}

/// Telegram alerts that failed to send — the recoverability queue (docs
/// NON_FUNCTIONAL: no silently lost signal). Postgres is the source of truth;
/// a resend pass retries them next cycle.
model UndeliveredAlert {
  id          String    @id @default(uuid())
  /// The rendered message text.
  payload     String
  runId       String?
  attempts    Int       @default(0)
  createdAt   DateTime  @default(now())
  deliveredAt DateTime?

  @@index([deliveredAt])
  @@map("undelivered_alert")
}

/// Every candidate that did NOT become a signal, with the stage + reason it was
/// dropped — the auditable rejection trail (docs: "every reject has a reason").
model SignalRejection {
  id           String   @id @default(uuid())
  runId        String
  createdAt    DateTime @default(now())
  instrumentId String
  symbol       String
  /// strategy | signal-math | portfolio
  stage        String
  reason       String
  detail       String

  @@index([runId])
  @@index([reason])
  @@map("signal_rejection")
}

/// Archived news article — the sentiment asset (ROADMAP B3). The archive is the
/// asset: we collect now so FinBERT (B6) can score it retroactively; every week
/// not collecting is a week of sentiment backtest lost. Append-only.
///
/// Point-in-time discipline: `fetchedAt` is the as-of date — when WE could have
/// known it — and is what the sentiment backtest must key on. `publishedAt` is
/// the feed's own timestamp (can be backdated/wrong) and must NEVER be used as
/// the as-of date. Same lookahead rule the fundamentals pipeline (B4) depends on.
model NewsArticle {
  id              String   @id @default(uuid())
  /// Feed of origin: ET_MARKETS | MONEYCONTROL | BSE_ANNOUNCEMENTS | GOOGLE_NEWS
  source          String
  /// Canonical article URL. (source, url) is the idempotency key — re-ingesting
  /// the same article no-ops rather than duplicating.
  url             String
  title           String
  /// Normalized title (lowercased, punctuation-stripped, collapsed) — the basis
  /// for cross-source Jaccard dedup and a fast lookup key.
  titleNormalized String
  /// Article body/summary when the feed provides one (RSS description / content).
  body            String?
  /// Canonical universe symbols matched in the headline (conservative; may be []).
  symbols         String[]
  /// Feed-declared publish time. NOT the as-of date (see model note).
  publishedAt     DateTime
  /// When OUR collector captured it. For live rows this is the honest as-of
  /// moment; for historical (GDELT) rows it is merely the import time — always
  /// read `availableAt` for point-in-time work.
  fetchedAt       DateTime @default(now())
  /// THE as-of moment (B3.5): when the platform could have known this article.
  /// Live rows: = fetchedAt. Historical rows: publishedAt + a configured
  /// latency margin (GDELT_LATENCY_MINUTES). All research reads THIS field.
  availableAt     DateTime
  /// Provenance (B3.5): which collection path produced the row. Research must
  /// always know live-captured from retro-imported.
  origin          NewsOrigin
  createdAt       DateTime @default(now())

  // ── FinBERT sentiment (ROADMAP B6, scored by the sidecar) ──
  /// positive − negative ∈ [−1, 1] — the aggregation-friendly scalar.
  sentimentScore    Float?
  /// argmax label: positive | negative | neutral.
  sentimentLabel    String?
  sentimentPositive Float?
  sentimentNegative Float?
  sentimentNeutral  Float?
  /// "<model>@<revision-prefix>" that produced the score — a model bump never
  /// silently mixes scoring regimes (re-score detects the mismatch).
  sentimentModel    String?
  sentimentScoredAt DateTime?

  @@unique([source, url])
  @@index([titleNormalized])
  @@index([publishedAt])
  @@index([fetchedAt])
  @@index([availableAt])
  @@index([sentimentScoredAt])
  @@map("news_article")
}

/// How a NewsArticle entered the archive (B3.5 provenance).
enum NewsOrigin {
  /// Captured live from an RSS/Atom feed poll (as-of = capture time).
  LIVE_RSS
  /// Captured live from the BSE announcements API (as-of = capture time).
  LIVE_BSE
  /// Retro-imported from the GDELT historical archive (as-of = publishedAt + latency).
  GDELT
}

/// Point-in-time quarterly fundamentals (ROADMAP B4). One row per (symbol,
/// periodEnd). The as-of key is `announcedAt` (BSE result-announcement
/// dissemination time) — NEVER `periodEnd`: a June quarter's EPS did not exist
/// publicly until its results were announced in July. When no BSE announcement
/// could be matched, `fallbackAvailableAt` (periodEnd + SEBI deadline: 45d
/// quarterly / 60d annual) is the conservative availability date.
model QuarterlyFundamental {
  id                  String    @id @default(uuid())
  /// Canonical NSE universe symbol (e.g. RELIANCE).
  symbol              String
  /// Quarter end date (e.g. 2026-06-30).
  periodEnd           DateTime  @db.Date
  /// EPS in ₹ for the quarter (Screener "EPS in Rs", consolidated preferred).
  epsBasic            Float
  /// ₹ crore.
  netProfit           Float?
  /// ₹ crore.
  sales               Float?
  /// BSE result-announcement dissemination time — the honest as-of moment.
  announcedAt         DateTime?
  /// Conservative availability when announcedAt is unmatched (SEBI deadline).
  fallbackAvailableAt DateTime  @db.Date
  /// 'consolidated' | 'standalone' (Screener table used).
  basis               String
  /// BSE scrip code discovered for the symbol (from the Screener page link).
  bseScripCode        String?
  fetchedAt           DateTime
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([symbol, periodEnd])
  @@index([symbol, announcedAt])
  @@map("quarterly_fundamental")
}

/// Weekly snapshot of current headline ratios (ROADMAP B4 clock #2): builds a
/// native point-in-time archive going forward. `fetchedAt` is the as-of key.
model FundamentalSnapshot {
  id        String   @id @default(uuid())
  symbol    String
  fetchedAt DateTime
  pe        Float?
  /// ₹ crore.
  marketCap Float?
  bookValue Float?
  roePct    Float?
  /// Full parsed ratio set (name → value) for future factors.
  raw       Json
  createdAt DateTime @default(now())

  @@index([symbol, fetchedAt])
  @@map("fundamental_snapshot")
}
